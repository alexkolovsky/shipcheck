{
  "name": "shipcheckit",
  "version": "0.5.1",
  "description": "Catch common website launch mistakes before your users do. A practical pre-launch checker for SEO, accessibility, performance, analytics, and security.",
  "type": "module",
  "license": "MIT",
  "author": "Alexander Kolovsky",
  "homepage": "https://github.com/alexkolovsky/shipcheck#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexkolovsky/shipcheck.git"
  },
  "bugs": {
    "url": "https://github.com/alexkolovsky/shipcheck/issues"
  },
  "keywords": [
    "seo",
    "accessibility",
    "a11y",
    "performance",
    "analytics",
    "security",
    "headers",
    "lighthouse",
    "audit",
    "cli",
    "pre-launch",
    "ga4",
    "gtm",
    "ci"
  ],
  "bin": {
    "shipcheck": "dist/cli.js",
    "shipcheckit": "dist/cli.js"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
